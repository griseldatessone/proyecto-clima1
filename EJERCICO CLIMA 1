# ============================================================
# 1. IMPORTAR LIBRERÍAS NECESARIAS
# ============================================================

import requests
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import confusion_matrix, classification_report
from IPython.display import display # Importar la función 'display'


# ============================================================
# 2. SOLICITAR API KEY DE AEMET (SEGURA)
# ============================================================

# NOTA: Este bloque de código está duplicado en la celda. Asegúrate de tener una única API Key configurada.
#       Para evitar solicitarla dos veces, podrías mover la definición de API_KEY fuera de los bloques if/else
#       o asegurarte de que solo se ejecute una vez si se usa en un entorno interactivo.
API_KEY = input("Introduce tu API Key de AEMET: ")

url_aemet = "https://opendata.aemet.es/opendata/api/observacion/convencional/todas"
params = {"api_key": API_KEY}

respuesta = requests.get(url_aemet, params=params)

if respuesta.status_code != 200:
    print("Error al conectar con AEMET. Revisa tu API Key.")
else:
    info = respuesta.json()
    url_datos = info.get("datos", None)

    if url_datos:
        datos_raw = requests.get(url_datos)
        with open("datos_aemet.json", "w", encoding="utf-8") as f:
            f.write(datos_raw.text)
        print("Datos meteorológicos descargados correctamente (datos_aemet.json).")
    else:
        print("No se encontró el enlace a los datos en la respuesta de AEMET.")


# ============================================================
# 3. CARGAR EL DATASET ATMOSFÉRICO (EL QUE TE DIO TU PROFESORA)
# ============================================================

# IMPORTANTE: Sube tu CSV a Colab antes de ejecutar esta línea.
# La 'KeyError: "CO2"' indica que la columna 'CO2' no se encuentra en el archivo 'datos_atmosfericos.csv'.
# Asegúrate de que el archivo CSV esté subido y contenga esta columna (y 'PM25', 'Humedad', 'Temperatura', 'Etiqueta').
df = pd.read_csv("datos_atmosfericos.csv")

print("Primeras filas del dataset original:")
display(df.head())


# ============================================================
# 4. LIMPIEZA CRÍTICA DEL DATASET
# ============================================================

# 4.1 Eliminar CO2 negativos
df = df[df["CO2"] >= 0]

# 4.2 Detectar picos de PM2.5 asociados a humedad sospechosa
# (si no tienes columna 'fecha', elimina la línea de sort_values)

if "fecha" in df.columns:
    df = df.sort_values("fecha")

df["PM25_media"] = df["PM25"].rolling(window=5, center=True).mean()

cond_pico = df["PM25"] > 3 * df["PM25_media"]
cond_humedad_rara = (df["Humedad"] == 0) | (df["Humedad"] == 100) | (df["Humedad"].isna())

df = df[~(cond_pico & cond_humedad_rara)]

# 4.3 Eliminar duplicados y nulos
df = df.drop_duplicates()
df = df.dropna()

print("Dataset limpio:")
display(df.head())


# ============================================================
# 5. PREPARAR VARIABLES PARA EL MODELO
# ============================================================

X = df[["PM25", "CO2", "Humedad", "Temperatura"]]
y = df["Etiqueta"]


# ============================================================
# 6. DIVISIÓN TRAIN/TEST (70/30)
# ============================================================

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42, stratify=y
)


# ============================================================
# 7. ENTRENAMIENTO DEL MODELO (Random Forest)
# ============================================================

modelo = RandomForestClassifier(random_state=42)
modelo.fit(X_train, y_train)


# ============================================================
# 8. EVALUACIÓN Y MATRIZ DE CONFUSIÓN
# ============================================================

y_pred = modelo.predict(X_test)

etiquetas = sorted(y.unique())
matriz = confusion_matrix(y_test, y_pred, labels=etiquetas)

print("Matriz de confusión:")
print(pd.DataFrame(matriz, index=etiquetas, columns=etiquetas))

print("\nInforme de clasificación:")
print(classification_report(y_test, y_pred))
