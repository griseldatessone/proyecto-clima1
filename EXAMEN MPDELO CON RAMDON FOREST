# 6. GENERACIÓN VISUAL DE LA MATRIZ DE CONFUSIÓN
def generar_matriz_visual(y_test, y_pred):
    # Creamos la matriz matemática
    cm = confusion_matrix(y_test, y_pred)

    # Configuramos el aspecto visual
    plt.figure(figsize=(8, 6))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=['Aire Limpio', 'Calima', 'Polución'],
                yticklabels=['Aire Limpio', 'Calima', 'Polución'])

    plt.title('Matriz de Confusión: Vigilancia Atmosférica')
    plt.ylabel('Realidad (Lo que pasó)')
    plt.xlabel('Predicción (Lo que dijo la IA)')
    plt.show()

# Llamamos a la función
generar_matriz_visual(y_test, y_pred)
